{
  "redirects": [
    {
      "source": "/explore",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/guide/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/profile",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/profile/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/login",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/register",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/payment",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/success",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/_internal/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/seo-health",
      "destination": "/api/seo-health"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Gg]ooglebot|[Gg]oogle-[Ii]nspection[Tt]ool|[Gg]oogle[Oo]ther|[Aa]ds[Bb]ot-[Gg]oogle|[Aa]pi[sS]-[Gg]oogle|[Mm]ediapartners-[Gg]oogle|[Bb]ingbot|[Yy]andex|[Bb]aiduspider|[Dd]uck[Dd]uck[Bb]ot|[Ss]lurp|facebookexternalhit|[Ff]acebot|[Tt]witterbot|[Ll]inked[Ii]n[Bb]ot|[Rr]ogerbot|[Aa]pplebot|[Ww]hats[Aa]pp|[Tt]elegram[Bb]ot|[Dd]iscord[Bb]ot|[Cc]rawler|[Ss]pider|[Bb]ot).*"
        }
      ],
      "destination": "/api/seo-render?route=explore"
    },
    {
      "source": "/itinerary",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Gg]ooglebot|[Gg]oogle-[Ii]nspection[Tt]ool|[Gg]oogle[Oo]ther|[Aa]ds[Bb]ot-[Gg]oogle|[Aa]pi[sS]-[Gg]oogle|[Mm]ediapartners-[Gg]oogle|[Bb]ingbot|[Yy]andex|[Bb]aiduspider|[Dd]uck[Dd]uck[Bb]ot|[Ss]lurp|facebookexternalhit|[Ff]acebot|[Tt]witterbot|[Ll]inked[Ii]n[Bb]ot|[Rr]ogerbot|[Aa]pplebot|[Ww]hats[Aa]pp|[Tt]elegram[Bb]ot|[Dd]iscord[Bb]ot|[Cc]rawler|[Ss]pider|[Bb]ot).*"
        }
      ],
      "destination": "/api/seo-render?route=itinerary"
    },
    {
      "source": "/tour/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Gg]ooglebot|[Gg]oogle-[Ii]nspection[Tt]ool|[Gg]oogle[Oo]ther|[Aa]ds[Bb]ot-[Gg]oogle|[Aa]pi[sS]-[Gg]oogle|[Mm]ediapartners-[Gg]oogle|[Bb]ingbot|[Yy]andex|[Bb]aiduspider|[Dd]uck[Dd]uck[Bb]ot|[Ss]lurp|facebookexternalhit|[Ff]acebot|[Tt]witterbot|[Ll]inked[Ii]n[Bb]ot|[Rr]ogerbot|[Aa]pplebot|[Ww]hats[Aa]pp|[Tt]elegram[Bb]ot|[Dd]iscord[Bb]ot|[Cc]rawler|[Ss]pider|[Bb]ot).*"
        }
      ],
      "destination": "/api/seo-render?route=tour&slug=:slug"
    },
    {
      "source": "/tours/:city/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Gg]ooglebot|[Gg]oogle-[Ii]nspection[Tt]ool|[Gg]oogle[Oo]ther|[Aa]ds[Bb]ot-[Gg]oogle|[Aa]pi[sS]-[Gg]oogle|[Mm]ediapartners-[Gg]oogle|[Bb]ingbot|[Yy]andex|[Bb]aiduspider|[Dd]uck[Dd]uck[Bb]ot|[Ss]lurp|facebookexternalhit|[Ff]acebot|[Tt]witterbot|[Ll]inked[Ii]n[Bb]ot|[Rr]ogerbot|[Aa]pplebot|[Ww]hats[Aa]pp|[Tt]elegram[Bb]ot|[Dd]iscord[Bb]ot|[Cc]rawler|[Ss]pider|[Bb]ot).*"
        }
      ],
      "destination": "/api/seo-render?route=tours-clean&city=:city&slug=:slug"
    },
    { "source": "/(.*)", "destination": "/_spa.html" }
  ]
}